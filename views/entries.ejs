<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <header class="site-header">
      <h1>Notes</h1>
      <nav>
        <a href="/">Home</a>
        <a href="/entries">Entries</a>
      </nav>
    </header>
    <main>
      <ul>
        <% entries.forEach(entry => { %>
          <li><%= entry.title %></li>
        <% }); %>
      </ul>
    </main>
  </body>
</html>