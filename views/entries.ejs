<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>
    <header class="site-header">
      <h1>Notes</h1>
      <nav>
        <a href="/">Home</a>
        <a href="/entries">Entries</a>
      </nav>
    </header>
    <main>
      <form id="entry-form">
        <input type="text" name="title" placeholder="Title">
        <input type="text" name="body" placeholder="Body">
        <button type="submit">Add entry</button>
      </form>
      <ul id="entries">
        <% entries.forEach((entry, index) => { %>
          <li data-id="<%= index %>" data-title="<%= entry.title %>" data-body="<%= entry.body %>">
            <span class="entry-display"><strong><%= entry.title %>:</strong> <%= entry.body %></span>
            <button class="edit-btn" type="button">Edit</button>
            <button class="delete-btn" type="button">Delete</button>
          </li>
        <% }); %>
      </ul>

      <section class="classic-form">
        <h2>Classic form (no JavaScript)</h2>
        <form method="POST" action="/entries/classic">
          <input type="text" name="title" placeholder="Title">
          <input type="text" name="body" placeholder="Body">
          <button type="submit">Add entry the classic way</button>
        </form>
      </section>
    </main>
    <script src="/app.js" defer></script>
  </body>
</html>